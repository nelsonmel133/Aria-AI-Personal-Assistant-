{
  "expo": {
    "name": "Aria",
    "slug": "aria",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "scheme": "aria",
    "userInterfaceStyle": "automatic",
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#0F1115"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.yourname.aria",
      "infoPlist": {
        "NSMicrophoneUsageDescription": "Aria uses the microphone for voice input.",
        "NSSpeechRecognitionUsageDescription": "Aria uses speech recognition to transcribe voice messages.",
        "NSFaceIDUsageDescription": "Aria uses Face ID to keep your data secure."
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#0F1115"
      },
      "package": "com.yourname.aria",
      "permissions": [
        "RECORD_AUDIO",
        "USE_BIOMETRIC",
        "USE_FINGERPRINT"
      ]
    },
    "plugins": [
      "expo-router",
      "expo-secure-store",
      "expo-font",
      [
        "expo-notifications",
        {
          "icon": "./assets/notification-icon.png",
          "color": "#E8C77A"
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    }
  }
}
